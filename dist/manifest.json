{
  "manifest_version": 3,
  "name": "Gen 3 OU Tools",
  "version": "1.0.0",
  "description": "Team prediction tool for Pokemon Showdown's Gen 3 OU format",
  "author": "",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://play.pokemonshowdown.com/*",
    "https://*.psim.us/*",
    "https://*.smogon.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://play.pokemonshowdown.com/*",
        "https://*.psim.us/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],

"web_accessible_resources": [
    {
      "matches": [
        "https://play.pokemonshowdown.com/*",
        "https://*.psim.us/*"
      ],
      "resources": [
        "main.js",
        "main.css"
      ]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}