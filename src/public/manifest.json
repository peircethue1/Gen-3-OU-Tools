{
  "manifest_version": 3,
  "name": "Gen 3 OU Tools",
  "version": "1.0.0",
  "description": "Damage calculator, team prediction, and pokemon information tools for Pokemon Showdown's Gen 3 OU format",
  "author": "",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://play.pokemonshowdown.com/*",
    "*://*.psim.us/*",
    "*://*.smogon.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://play.pokemonshowdown.com/*",
        "*://*.psim.us/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://play.pokemonshowdown.com/*",
        "*://*.psim.us/*"
      ],
      "resources": [
        "main.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}